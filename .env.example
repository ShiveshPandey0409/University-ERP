# ---- Database ----
DATABASE_URL="postgresql://erp:erp_dev_password@localhost:5432/erp?schema=public"

# ---- Redis ----
REDIS_URL="redis://localhost:6379"

# ---- Auth ----
JWT_ACCESS_SECRET="dev-only-change-me-access-secret-please-32chars-min"
JWT_ACCESS_TTL="15m"
REFRESH_TTL_DAYS="30"
ARGON_MEMORY_COST="19456"
ARGON_TIME_COST="2"
ARGON_PARALLELISM="1"
COOKIE_DOMAIN="localhost"
COOKIE_SECURE="false"

# ---- CORS / URLs ----
CORS_ORIGINS="http://localhost:3000"
API_PORT="4000"
API_INTERNAL_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Object storage (MinIO / S3) ----
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="erp-files"
S3_FORCE_PATH_STYLE="true"

# ---- Email (MailHog in dev) ----
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="no-reply@erp.local"

# ---- Rate limiting ----
LOGIN_RATE_MAX="5"
LOGIN_RATE_WINDOW_SEC="300"

# ---- Seed bootstrap super admin ----
SEED_SUPERADMIN_USERNAME="superadmin"
SEED_SUPERADMIN_EMAIL="superadmin@erp.local"
SEED_SUPERADMIN_PASSWORD="ChangeMe!2026"
